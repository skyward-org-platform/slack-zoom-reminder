# Path to a Google Cloud service account JSON key with Calendar API enabled.
# The service account email must be granted access to each calendar in clients.yaml.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Slack bot token (xoxb-...). Bot needs `chat:write` and must be invited to each channel.
SLACK_BOT_TOKEN=xoxb-replace-me

# 'test' routes messages to test channels; 'prod' routes to real client channels.
ENV=test
